[remap]

importer=""

[application]

config/name="كِسرة"
config/description="Egyptian Brick-Breaker — 9 Worlds, 100+ Levels"
run/main_scene="res://src/ui/main_menu.tscn"
config/icon="res://assets/ui/icon.png"

[rendering]

renderer/tier=1
2d/snapping/enabled=true

[display]

window/size/viewport_width=480
window/size/viewport_height=720
window/size/mode=0
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[input]

ui_left=[keyboard:A]
ui_right=[keyboard:D]
ui_accept=[keyboard:Space,keyboard:Enter]
pause=[keyboard:Escape]
